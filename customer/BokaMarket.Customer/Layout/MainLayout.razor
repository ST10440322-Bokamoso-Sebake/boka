@inherits LayoutComponentBase
@inject IDataService Data
@inject NavigationManager Nav
@implements IDisposable

<div class="page">
    <nav class="navbar">
        <a class="brand" href="/">Boka's Yarn Market</a>
        <div class="nav-links" style="display:flex; align-items:center;">
            <a href="/">Home</a>
            <a href="/catalog">Shop All</a>
            <a href="/about">Our Story</a>
            <a href="/contact">Contact</a>
            
            <span style="border-left: 1px solid #ddd; margin: 0 10px; height: 20px;"></span>
            
            @if (Data.CurrentUser != null)
            {
                <a href="/profile" style="color: var(--primary); font-weight: 600;">
                    <i class="bi bi-person-circle"></i> @Data.CurrentUser.FirstName
                </a>
            }
            else
            {
                <a href="/login">Sign In</a>
            }

            <a href="/cart" class="cart-icon" style="margin-left: 15px;">
                <i class="bi bi-bag"></i>
                <span class="cart-count">2</span> <!-- Hardcoded for now -->
            </a>
        </div>
    </nav>
    <main>
        @Body
    </main>
    <footer>
        <div style="font-size: 1.2rem; font-weight: 800; color: var(--primary); margin-bottom: 5px;">Boka's Yarn Market</div>
        <div>Crafting Slowly, Living Intentionally.</div>
        <div>Cape Town, South Africa</div>
        <a href="http://localhost:5000" class="admin-link">Admin Dashboard</a> <!-- Or relative link if hosted together -->
    </footer>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
