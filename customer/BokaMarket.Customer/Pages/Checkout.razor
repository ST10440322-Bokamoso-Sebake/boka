@page "/checkout"

<div style="background: white; min-height: 100vh;">
    <div style="max-width: 1000px; margin: 0 auto; display: flex;">
        
        <!-- Left Side: Form -->
        <div style="flex: 1; padding: 4rem 3rem 4rem 1rem;">
            <a href="/cart" style="text-decoration: none; color: var(--primary); font-size: 0.85rem; font-weight: 600;">
                <i class="bi bi-chevron-left"></i> Return to Cart
            </a>

            <h2 style="font-size: 1.6rem; font-weight: 800; margin-top: 2rem; margin-bottom: 1.5rem;">Contact Information</h2>
            
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <input type="email" placeholder="Email Address" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <label style="font-size: 0.85rem; display: flex; align-items: center; gap: 8px; color: var(--text-muted);">
                    <input type="checkbox" checked /> Email me with news and offers
                </label>
            </div>

            <h2 style="font-size: 1.6rem; font-weight: 800; margin-top: 3rem; margin-bottom: 1.5rem;">Shipping Address</h2>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <input type="text" placeholder="First Name" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <input type="text" placeholder="Last Name" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <input type="text" placeholder="Address" style="grid-column: span 2; width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <input type="text" placeholder="Apartment, suite, etc. (optional)" style="grid-column: span 2; width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <input type="text" placeholder="City" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <input type="text" placeholder="Postal Code" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <input type="text" placeholder="Phone Number" style="grid-column: span 2; width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
            </div>

            <h2 style="font-size: 1.6rem; font-weight: 800; margin-top: 3rem; margin-bottom: 1.5rem;">Payment Method</h2>
            <div style="border: 1px solid #ddd; border-radius: 8px; overflow: hidden; margin-bottom: 2rem;">
                <label style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; border-bottom: 1px solid #ddd; background: #fafafa; cursor: pointer;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <input type="radio" name="payment" checked />
                        <span style="font-weight: 600;">EFT / Bank Transfer</span>
                    </div>
                    <i class="bi bi-bank" style="font-size: 1.2rem; color: var(--text-muted);"></i>
                </label>
                <div style="padding: 1.5rem; font-size: 0.9rem; color: var(--text-muted); background: white; line-height: 1.6;">
                    Make your payment directly into our bank account. Please use your Order ID as the payment reference. Your order will not be shipped until the funds have cleared in our account.
                </div>

                <label style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; border-top: 1px solid #ddd; cursor: pointer;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <input type="radio" name="payment" />
                        <span style="font-weight: 600;">Lay-by (30% Deposit)</span>
                    </div>
                </label>
            </div>

            <button class="btn-primary" style="width: 100%; padding: 16px; font-size: 1.1rem; border-radius: 8px;" @onclick="CompleteOrder">Complete Purchase</button>
        </div>

        <!-- Right Side: Mini Summary -->
        <div style="flex: 0.8; background: var(--bg-main); padding: 4rem 1rem 4rem 3rem; border-left: 1px solid #eee;">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                <div style="position: relative;">
                    <img src="images/78.png" style="width: 65px; height: 65px; border-radius: 8px; object-fit: cover; border: 1px solid #ddd;" onerror="this.src='https://placehold.co/65x65/F7E8FA/7E3091';" />
                    <span style="position: absolute; top: -8px; right: -8px; background: rgba(126, 48, 145, 0.9); color: white; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: bold;">1</span>
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 600; font-size: 0.95rem;">Chunky Merino Cardigan</div>
                    <div style="font-size: 0.8rem; color: var(--text-muted);">Custom Fit | Lavender</div>
                </div>
                <div style="font-weight: 600; font-size: 0.95rem;">R450</div>
            </div>

            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem;">
                <div style="position: relative;">
                    <img src="images/79.png" style="width: 65px; height: 65px; border-radius: 8px; object-fit: cover; border: 1px solid #ddd;" onerror="this.src='https://placehold.co/65x65/F7E8FA/7E3091';" />
                    <span style="position: absolute; top: -8px; right: -8px; background: rgba(126, 48, 145, 0.9); color: white; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: bold;">1</span>
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 600; font-size: 0.95rem;">Bamboo Crochet Hook Set</div>
                    <div style="font-size: 0.8rem; color: var(--text-muted);">Ergonomic 2-6mm</div>
                </div>
                <div style="font-weight: 600; font-size: 0.95rem;">R35</div>
            </div>

            <div style="display: flex; gap: 10px; margin-bottom: 2rem;">
                <input type="text" placeholder="Discount code" style="flex: 1; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                <button class="btn-primary" style="background: #e1e1e1; color: var(--text-muted); font-weight: 700; border-radius: 8px;">Apply</button>
            </div>

            <div style="border-top: 1px solid #ddd; padding-top: 1.5rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.95rem;">
                    <span style="color: var(--text-muted);">Subtotal</span>
                    <span style="font-weight: 600;">R485.00</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.95rem;">
                    <span style="color: var(--text-muted);">Shipping</span>
                    <span style="color: var(--text-muted);">Free (Local Pickup)</span>
                </div>
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; font-size: 1.4rem; font-weight: 800;">
                    <span>Total</span>
                    <span style="color: var(--primary);">
                        <span style="font-size: 0.8rem; font-weight: 400; color: var(--text-muted); margin-right: 5px;">ZAR</span>R485.00
                    </span>
                </div>
            </div>

            <div style="margin-top: 2rem; padding: 1rem; border: 1px solid var(--primary-light); background: var(--primary-bg); border-radius: 8px; font-size: 0.85rem; color: var(--primary); font-weight: 600; display: flex; gap: 10px; align-items: flex-start;">
                <i class="bi bi-info-circle-fill" style="margin-top: 2px;"></i>
                <span>Your purchase supports sustainable, local artisanship.</span>
            </div>
        </div>

    </div>
</div>

@if (orderCompleted)
{
    <!-- Order confirmation modal overlay -->
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 1000; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
        <div style="background: white; padding: 3rem; border-radius: 12px; text-align: center; max-width: 500px; width: 90%;">
            <div style="width: 80px; height: 80px; background: #E8F5E9; color: #27AE60; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 1.5rem auto;">
                <i class="bi bi-check-lg"></i>
            </div>
            <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 1rem;">Order Confirmed!</h2>
            <p style="color: var(--text-muted); line-height: 1.6; margin-bottom: 2rem;">
                Thank you for your purchase. We've received your order (#BYM-9418) and will begin handcrafting your items soon. An email with payment details has been sent to your address.
            </p>
            <a href="/" class="btn-primary" style="display: block;">Return to Home</a>
        </div>
    </div>
}

@code {
    private bool orderCompleted = false;

    private void CompleteOrder()
    {
        orderCompleted = true;
    }
}
