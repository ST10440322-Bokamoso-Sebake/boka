@page "/register"
@inject IDataService Data
@inject NavigationManager Nav

<div style="max-width: 500px; margin: 4rem auto; background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 0.5rem; text-align: center;">Create an Account</h2>
    <p style="color: var(--text-muted); text-align: center; margin-bottom: 2rem;">Join the Boka family</p>

    @if (registerFailed)
    {
        <div style="background: #FADBD8; color: #E74C3C; padding: 10px; border-radius: 8px; margin-bottom: 1rem; font-size: 0.9rem; text-align: center;">
            Email already exists or invalid data.
        </div>
    }

    <form @onsubmit="HandleRegister" @onsubmit:preventDefault="true" style="display: flex; flex-direction: column; gap: 1rem;">

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">First Name</label>
                <input type="text" @bind="newUser.FirstName" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
            </div>
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">Last Name</label>
                <input type="text" @bind="newUser.LastName" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
            </div>
        </div>

        <div>
            <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">Email Address</label>
            <input type="email" @bind="newUser.Email" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
        </div>

        <div>
            <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">Password</label>
            <input type="password" @bind="newUser.Password" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
        </div>

        <button type="submit" class="btn-primary" style="width: 100%; padding: 14px; margin-top: 1rem;">Sign Up</button>
    </form>

    <div style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: var(--text-muted);">
        Already have an account? <a href="/login" style="color: var(--primary); font-weight: 600; text-decoration: none;">Sign in</a>
    </div>
</div>

@code {
    private User newUser = new();
    private bool registerFailed = false;

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(newUser.Email) || string.IsNullOrWhiteSpace(newUser.Password))
        {
            registerFailed = true;
            return;
        }

        registerFailed = !await Data.RegisterAsync(newUser);
        if (!registerFailed)
        {
            Nav.NavigateTo("/profile");
        }
    }
}
