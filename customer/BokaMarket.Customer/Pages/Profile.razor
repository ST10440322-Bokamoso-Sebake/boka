@page "/profile"
@inject IDataService Data
@inject NavigationManager Nav

@if (user == null)
{
    <div style="text-align: center; padding: 4rem;">Authenticating...</div>
}
else
{
    <div style="max-width: 800px; margin: 4rem auto; display: grid; grid-template-columns: 250px 1fr; gap: 2rem;">
        <!-- Sidebar Menu -->
        <div style="background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 15px rgba(0,0,0,0.03); align-self: start;">
            <div style="text-align: center; margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
                <div style="width: 60px; height: 60px; background: var(--primary-bg); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; margin: 0 auto 10px auto;">
                    @(user.FirstName?.FirstOrDefault() ?? 'U')
                </div>
                <div style="font-weight: 700;">@user.FirstName @user.LastName</div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">@user.Email</div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <a href="/profile" style="padding: 10px; border-radius: 8px; background: var(--primary); color: white; text-decoration: none; font-weight: 600; font-size: 0.9rem;"><i class="bi bi-person-fill" style="margin-right: 8px;"></i> My Details</a>
                <button @onclick="HandleLogout" style="padding: 10px; border-radius: 8px; border: none; background: transparent; color: #E74C3C; text-align: left; cursor: pointer; font-weight: 600; font-size: 0.9rem; font-family: inherit;"><i class="bi bi-box-arrow-right" style="margin-right: 8px;"></i> Sign Out</button>
            </div>
        </div>

        <!-- Details Editor -->
        <div style="background: white; border-radius: 12px; padding: 2.5rem; box-shadow: 0 4px 15px rgba(0,0,0,0.03);">
            <h2 style="font-size: 1.5rem; font-weight: 800; color: var(--primary); margin-bottom: 1.5rem;">Personal Details</h2>

            @if (saved)
            {
                <div style="background: #E8F5E9; color: #27AE60; padding: 10px; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; display: flex; align-items: center; gap: 10px;">
                    <i class="bi bi-check-circle-fill"></i> Profile updated successfully!
                </div>
            }

            <form @onsubmit="SaveProfile" @onsubmit:preventDefault="true" style="display: flex; flex-direction: column; gap: 1.2rem;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem;">
                    <div>
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">First Name</label>
                        <input type="text" @bind="user.FirstName" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                    </div>
                    <div>
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">Last Name</label>
                        <input type="text" @bind="user.LastName" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                    </div>
                </div>

                <div>
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">Phone Number</label>
                    <input type="text" @bind="user.Phone" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                </div>

                <div>
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem;">Shipping Address</label>
                    <input type="text" @bind="user.Address" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.95rem; box-sizing: border-box;" />
                </div>

                <div style="margin-top: 1rem;">
                    <button type="submit" class="btn-primary" style="padding: 12px 24px;">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
}

@code {
    private User? user;
    private bool saved = false;

    protected override void OnInitialized()
    {
        user = Data.CurrentUser;
        if (user == null)
        {
            Nav.NavigateTo("/login");
        }
    }

    private async void SaveProfile()
    {
        if (user != null)
        {
            Data.UpdateProfile(user);
            saved = true;
            StateHasChanged();
            await Task.Delay(3000);
            saved = false;
            StateHasChanged();
        }
    }

    private void HandleLogout()
    {
        Data.Logout();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
