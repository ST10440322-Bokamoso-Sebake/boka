@page "/checkout/success/{orderNumber}"
@inject NavigationManager Nav
@inject CartService CartService

<div style="background: white; min-height: 100vh; font-family: 'Outfit', sans-serif; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <div style="background: #F7F1F8; padding: 4rem 3rem; border-radius: 32px; text-align: center; max-width: 600px; width: 100%; box-shadow: 0 20px 40px rgba(126, 48, 145, 0.08); border: 1.5px solid #E8DAEF;">
        
        <div style="width: 120px; height: 120px; background: #E8F5E9; color: #27AE60; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 4rem; margin: 0 auto 2.5rem auto; box-shadow: 0 10px 25px rgba(39, 174, 96, 0.12);">
            <i class="bi bi-patch-check-fill"></i>
        </div>
        
        <h1 style="font-size: 2.8rem; font-weight: 900; color: #2D3436; margin-bottom: 1.2rem; letter-spacing: -0.5px;">Magical Success!</h1>
        
        <p style="color: #636E72; font-size: 1.2rem; line-height: 1.8; margin-bottom: 2.5rem;">
            Your payment for order <strong style="color: var(--primary);">#@orderNumber</strong> has been received with intentionality. We are now preparing your handcrafted treasures for their new home.
        </p>

        <div style="background: white; padding: 1.5rem; border-radius: 16px; margin-bottom: 3rem; display: flex; gap: 12px; align-items: center; justify-content: center; border: 1px solid #E8E8E8;">
            <i class="bi bi-envelope-heart" style="color: var(--primary); font-size: 1.4rem;"></i>
            <span style="font-weight: 600; color: #2D3436;">A mystical receipt is on its way to your inbox.</span>
        </div>
        
        <div style="display: flex; gap: 1rem; justify-content: center;">
            <button @onclick='() => Nav.NavigateTo("/")' class="btn-primary" style="padding: 18px 40px; font-size: 1.1rem; border-radius: 15px; font-weight: 700; flex: 1;">Return to Market</button>
            <button @onclick='() => Nav.NavigateTo("/catalog")' class="btn-secondary" style="padding: 18px 40px; font-size: 1.1rem; border-radius: 15px; font-weight: 700; flex: 1; border: 2px solid var(--primary); background: transparent; color: var(--primary);">Keep Exploring</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? orderNumber { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Clear cart just in case it wasn't cleared in the redirect flow
        await CartService.ClearCartAsync();
    }
}
