@page "/product/{Id:int}"
@inject IDataService Data

@if (product == null)
{
    <div style="padding: 4rem; text-align: center;">Product not found.</div>
}
else
{
    <div style="max-width: 1200px; margin: 0 auto; padding: 3rem 2.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
        
        <!-- Image Area -->
        <div>
            <!-- Let's map certain image files randomly to showcase the screenshot images -->
            <img src="https://localhost:7123/@product.ImageUrl" alt="@product.Name" style="width: 100%; border-radius: var(--border-radius); box-shadow: 0 4px 20px rgba(0,0,0,0.05); object-fit: cover;" onerror="this.src='https://placehold.co/600x600/F7E8FA/7E3091?text=Gallery';"/>
            
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1rem;">
                <img src="images/73.png" style="width: 100%; aspect-ratio: 1; border-radius: 8px; object-fit: cover; cursor: pointer;" />
                <img src="images/74.png" style="width: 100%; aspect-ratio: 1; border-radius: 8px; object-fit: cover; cursor: pointer;" />
                <img src="images/75.png" style="width: 100%; aspect-ratio: 1; border-radius: 8px; object-fit: cover; cursor: pointer;" />
                <img src="images/76.png" style="width: 100%; aspect-ratio: 1; border-radius: 8px; object-fit: cover; cursor: pointer;" />
            </div>
        </div>

        <!-- Details Area -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div>
                <div class="product-category" style="font-size: 0.85rem; margin-bottom: 8px;">@product.Category</div>
                <h1 style="font-size: 2.2rem; font-weight: 800; margin: 0; line-height: 1.2; color: var(--primary);">@product.Name</h1>
                <div class="product-price" style="font-size: 1.5rem; margin-top: 10px;">R@product.Price.ToString("N0")</div>
            </div>

            <p style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.6;">
                @product.Description
            </p>

            @if (product.InventoryCount < 10)
            {
                <div style="color: #E67E22; font-weight: 600; font-size: 0.9rem; padding: 10px; background: #FFF3E0; border-radius: 8px; width: fit-content;">
                    <i class="bi bi-fire"></i> Only @product.InventoryCount left in stock. Hurry!
                </div>
            }
            else
            {
                <div style="color: #27AE60; font-weight: 600; font-size: 0.9rem; padding: 10px; background: #E8F5E9; border-radius: 8px; width: fit-content;">
                    <i class="bi bi-check-circle"></i> In Stock
                </div>
            }

            <div style="border-top: 1px solid #eee; padding-top: 2rem; margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;">
                <label style="font-size: 0.9rem; font-weight: 700;">Quantity</label>
                <div style="display: flex; gap: 1rem;">
                    <input type="number" min="1" max="@product.InventoryCount" @bind="quantity" style="width: 80px; padding: 0.8rem; border: 1px solid #ddd; border-radius: 8px; font-size: 1rem; text-align: center;" />
                    <button class="btn-primary" style="flex: 1;" @onclick="AddToCart">Add to Cart</button>
                    <button class="btn-primary" style="background: white; color: var(--primary); border: 2px solid var(--primary);" @onclick="StartLayby">Lay-by This Item</button>

                </div>
            </div>

            <div style="margin-top: 2rem;">
                <h3 style="font-size: 1.1rem; margin-bottom: 1rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Shipping & Returns</h3>
                <ul style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; padding-left: 20px;">
                    <li>Free local pickup at our weekend markets.</li>
                    <li>Nationwide shipping via PEP Paxi (R60) or Aramex (R99).</li>
                    <li>No returns on customized or worn apparel.</li>
                </ul>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }
    
    private Product? product;
    private int quantity = 1;

    protected override async Task OnParametersSetAsync()
    {
        product = await Data.GetProductAsync(Id);
    }

    private void AddToCart()
    {
        // Simple mock method
        if (product != null)
        {
            Console.WriteLine($"Added {quantity} x {product.Name} to cart.");
        }
    }
    
    private void StartLayby()
    {
        // Simple mock method for Lay-by
        if (product != null)
        {
            Console.WriteLine($"Started lay-by for {product.Name}.");
        }
    }
}
