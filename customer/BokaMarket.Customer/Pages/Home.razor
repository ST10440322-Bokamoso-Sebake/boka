@page "/"
@inject IDataService Data

<PageTitle>BokaMarket | Artisanal Handcrafted Knitwear & Crochet</PageTitle>

<HeadContent>
    <meta name="description" content="Discover premium, sustainable, and artisanal handcrafted knitwear, crochet treasures, and high-quality yarn at BokaMarket. Crafted with care, made for you." />
    <meta name="keywords" content="crochet, knitwear, artisanal, luxury yarn, slow fashion, South Africa, boka yarn market" />
</HeadContent>

<div class="hero">
    <h1>Handcrafted with Care,<br/>Made for You.</h1>
    <p>We believe in slow fashion. Discover unique, artisanal knitwear and crochet pieces designed to bring joy and warmth without lasting environmental impact.</p>
    <a href="/catalog" class="btn-primary">Shop Our Collection</a>
</div>

<div style="text-align: center; margin-top: 4rem;">
    <h2 style="font-size: 2rem; color: var(--primary); font-weight: 800; margin-bottom: 0.5rem;">New Arrivals</h2>
    <p style="color: var(--text-muted); padding-bottom: 1rem;">Ethically crafted pieces to elevate your everyday.</p>
</div>

<div class="catalog-grid">
    @foreach (var product in featuredProducts)
    {
        <a href="/product/@product.Id" class="product-card">
            <!-- Using the local images provided by the user if we had them or placeholder -->
            <img src="https://localhost:7123/@product.ImageUrl" class="product-image" alt="@product.Name" onerror="this.src='https://placehold.co/400x400/F7E8FA/7E3091?text=Boka+Yarn';" />
            
            <div class="product-category">@product.Category</div>
            <h3 class="product-title">@product.Name</h3>
            <div class="product-price">R@product.Price.ToString("N0")</div>
            
            <button class="btn-primary" style="width: 100%; margin-top: 1rem; font-size: 0.85rem; padding: 0.6rem; background: var(--bg-main); color: var(--primary); border: 1px solid var(--primary);">
                View Details
            </button>
        </a>
    }
</div>

@code {
    private List<Product> featuredProducts = new();

    protected override async Task OnInitializedAsync()
    {
        // For the homepage, we just take the first few products
        var products = await Data.GetProductsAsync();
        featuredProducts = products.Take(4).ToList();
    }
}
