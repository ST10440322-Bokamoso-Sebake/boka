@inject NavigationManager Nav
@inject IDataService Data
@inject CartService Cart
@inject IConfiguration Config

<div style="background: var(--bg-main); padding: 4rem 2.5rem; text-align: center;">
    <h1 style="font-size: 2.5rem; color: var(--primary); font-weight: 800; margin-bottom: 0.5rem;">The Boka Collection</h1>
    <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">Browse all our artisanal fiber arts. Every piece is made slowly and intentionally.</p>
</div>

<div class="catalog-grid" style="padding: 1rem 2.5rem 4rem 2.5rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2.5rem;">
    @foreach (var product in products)
    {
        <div class="product-card" style="cursor: pointer; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; background: white; border-radius: 20px; padding: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.03);" @onclick='() => Nav.NavigateTo($"/product/{product.Id}")'>
            <div style="overflow: hidden; border-radius: 14px; position: relative; aspect-ratio: 1;">
                 <img src="@GetImageUrl(product.ImageUrl)" class="product-image" alt="@product.Name" onerror="this.src='https://placehold.co/400x400/F7E8FA/7E3091?text=Boka';" 
                     style="width: 100%; border-radius: 14px; object-fit: cover; transition: all 0.6s;"/>
                 <div class="image-overlay" style="position: absolute; inset: 0; background: rgba(126, 48, 145, 0.1); opacity: 0; transition: opacity 0.3s;"></div>
            </div>
            
            <div style="padding: 1.2rem 0.5rem 0.5rem 0.5rem;">
                <div class="product-category" style="font-size: 0.7rem; color: var(--primary); font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 6px; opacity: 0.8;">@product.Category</div>
                <h3 class="product-title" style="font-size: 1.15rem; font-weight: 800; margin: 0; color: #2D3436; line-height: 1.2;">@product.Name</h3>
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px;">
                    <div class="product-price" style="font-size: 1.25rem; font-weight: 900; color: var(--primary);">R @product.Price.ToString("N0")</div>
                    <button class="btn-primary" style="width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; padding: 0;" @onclick:stopPropagation="true" @onclick="() => Cart.AddToCartAsync(product)">
                        <i class="bi bi-bag-plus-fill" style="font-size: 1.2rem;"></i>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .product-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(126, 48, 145, 0.12); }
    .product-card:hover .product-image { transform: scale(1.1); }
    .product-card:hover .image-overlay { opacity: 1; }
</style>

@code {
    private List<Product> products = new();

    protected override async Task OnInitializedAsync()
    {
        products = await Data.GetProductsAsync();
    }

    private string GetImageUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return "https://placehold.co/400x400/F7E8FA/7E3091?text=Boka";
        if (url.StartsWith("http")) return url;
        
        var baseUrl = Config["ApiBaseUrl"] ?? "https://localhost:7123/";
        if (!baseUrl.EndsWith("/")) baseUrl += "/";
        return $"{baseUrl}{url}";
    }
}


