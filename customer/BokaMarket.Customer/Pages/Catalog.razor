@inject IDataService Data
@inject CartService Cart

<div style="background: var(--bg-main); padding: 4rem 2.5rem; text-align: center;">
    <h1 style="font-size: 2.5rem; color: var(--primary); font-weight: 800; margin-bottom: 0.5rem;">The Boka Collection</h1>
    <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">Browse all our artisanal fiber arts. Every piece is made slowly and intentionally.</p>
</div>

<div class="catalog-grid" style="padding-top: 1rem;">
    @foreach (var product in products)
    {
        <div class="product-card" style="cursor: pointer; transition: transform 0.3s; position: relative;" @onclick='() => Nav.NavigateTo($"/product/{product.Id}")'>
            <img src="https://localhost:7123/@product.ImageUrl" class="product-image" alt="@product.Name" onerror="this.src='https://placehold.co/400x400/F7E8FA/7E3091?text=Product';" 
                 style="width: 100%; border-radius: 12px; object-fit: cover; transition: all 0.5s;"/>
            
            <div style="padding: 1rem 0;">
                <div class="product-category" style="font-size: 0.75rem; color: var(--primary); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">@product.Category</div>
                <h3 class="product-title" style="font-size: 1.1rem; font-weight: 800; margin: 0; color: #2D3436;">@product.Name</h3>
                <div class="product-price" style="font-size: 1.2rem; font-weight: 900; color: var(--primary); margin: 8px 0;">R @product.Price.ToString("N0")</div>
                
                <button class="btn-primary" style="width: 100%; margin-top: 0.5rem; font-size: 0.9rem; padding: 0.8rem; border-radius: 8px;" @onclick:stopPropagation="true" @onclick="() => Cart.AddToCartAsync(product)">
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
            </div>
        </div>
    }
</div>

@inject NavigationManager Nav

@code {
    private List<Product> products = new();

    protected override async Task OnInitializedAsync()
    {
        products = await Data.GetProductsAsync();
    }
}
