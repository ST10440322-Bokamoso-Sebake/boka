@page "/catalog"
@inject IDataService Data

<div style="background: var(--bg-main); padding: 4rem 2.5rem; text-align: center;">
    <h1 style="font-size: 2.5rem; color: var(--primary); font-weight: 800; margin-bottom: 0.5rem;">The Boka Collection</h1>
    <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">Browse all our artisanal fiber arts. Every piece is made slowly and intentionally.</p>
</div>

<div class="catalog-grid" style="padding-top: 1rem;">
    @foreach (var product in products)
    {
        <a href="/product/@product.Id" class="product-card">
            <!-- Mock dynamic image logic based on what's available or fallback -->
            <img src="https://localhost:7123/@product.ImageUrl" class="product-image" alt="@product.Name" onerror="this.src='https://placehold.co/400x400/F7E8FA/7E3091?text=Product';" />
            
            <div class="product-category">@product.Category</div>
            <h3 class="product-title">@product.Name</h3>
            <div class="product-price">R@product.Price.ToString("N0")</div>
            
            <button class="btn-primary" style="width: 100%; margin-top: 1rem; font-size: 0.85rem; padding: 0.6rem; background: var(--bg-main); color: var(--primary); border: 1px solid var(--primary);">
                View Details
            </button>
        </a>
    }
</div>

@code {
    private List<Product> products = new();

    protected override async Task OnInitializedAsync()
    {
        products = await Data.GetProductsAsync();
    }
}
