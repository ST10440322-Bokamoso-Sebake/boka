@page "/orders"
@inject IDataService Data

<div class="page-header">
    <h1>Orders Management</h1>
    <p style="color: var(--text-muted);">Track and curate pending artisanal commissions.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">AWAITING DEPOSIT</div>
        <div class="stat-value">12</div>
        <div style="font-size: 0.75rem; color: var(--accent-green); margin-top: 8px;">↑ +2 from yesterday</div>
    </div>
    <div class="stat-card">
        <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">IN PRODUCTION</div>
        <div class="stat-value">08</div>
        <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 8px;">4 orders due this week</div>
    </div>
    <div class="stat-card">
        <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">READY FOR PICKUP</div>
        <div class="stat-value">05</div>
        <div style="font-size: 0.75rem; color: #E74C3C; margin-top: 8px;">Action required</div>
    </div>
    <div class="stat-card featured">
        <div style="font-size: 0.8rem; opacity: 0.8; margin-bottom: 8px;">TOTAL MONTHLY REVENUE</div>
        <div class="stat-value">R4,820</div>
        <div style="font-size: 0.75rem; opacity: 0.8; margin-top: 8px;">Crafted with intentionality</div>
    </div>
</div>

<div class="table-container">
    <div class="table-header">
        <h2 style="font-size: 1.25rem; font-weight: 600;">Active Orders</h2>
        <div>
            <button class="btn-primary" style="font-size: 0.85rem;" @onclick="AddNewOrder">+ ADD NEW ORDER</button>
            <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.6rem 1.2rem; border-radius: 10px; font-weight: 600;">DOWNLOAD CSV</button>
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Status</th>
                <th>Payment</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in orders)
            {
                <tr>
                    <td style="color: var(--primary); font-weight: 700;">@order.OrderNumber</td>
                    <td>
                        <div style="font-weight: 600;">@order.CustomerName</div>
                        <div style="font-size: 0.8rem; color: var(--text-muted);">@order.CustomerEmail</div>
                    </td>
                    <td>
                        <span class="status-badge @GetStatusClass(order.Status)">@order.Status.ToUpper()</span>
                    </td>
                    <td>
                        <div style="font-weight: 600;">@(order.IsFullyPaid ? "Fully Paid" : "Deposit Paid")</div>
                        <div style="font-size: 0.8rem; color: var(--text-muted);">(R@order.DepositPaid.ToString("N0"))</div>
                    </td>
                    <td>
                        <div style="display: flex; gap: 12px;">
                            <i class="bi bi-eye" style="cursor: pointer; color: var(--text-muted);"></i>
                            <i class="bi bi-pencil" style="cursor: pointer; color: var(--text-muted);" @onclick="() => EditOrder(order)"></i>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingOrder.Id == 0 ? "Add New Order" : "Edit Order")</h3>
                <i class="bi bi-x-lg" style="cursor:pointer;" @onclick="CloseModal"></i>
            </div>
            
            <EditForm Model="editingOrder" OnValidSubmit="SaveOrder">
                <DataAnnotationsValidator />
                
                <div class="form-group">
                    <label>Customer Name</label>
                    <InputText @bind-Value="editingOrder.CustomerName" class="form-control" />
                </div>
                
                <div class="form-group">
                    <label>Customer Email</label>
                    <InputText @bind-Value="editingOrder.CustomerEmail" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Status</label>
                    <InputSelect @bind-Value="editingOrder.Status" class="form-control">
                        <option value="Deposit Paid">Deposit Paid</option>
                        <option value="In Production">In Production</option>
                        <option value="Ready for Pickup">Ready for Pickup</option>
                    </InputSelect>
                </div>
                
                <div class="form-group">
                    <label>Total Amount (R)</label>
                    <InputNumber @bind-Value="editingOrder.TotalAmount" class="form-control" />
                </div>
                
                <div class="form-group">
                    <label>Deposit Paid (R)</label>
                    <InputNumber @bind-Value="editingOrder.DepositPaid" class="form-control" />
                </div>
                
                <div class="form-group">
                    <label>
                        <InputCheckbox @bind-Value="editingOrder.IsFullyPaid" /> Fully Paid
                    </label>
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn-primary">Save Order</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Order> orders = new();
    private bool showModal = false;
    private Order editingOrder = new();

    protected override async Task OnInitializedAsync()
    {
        orders = await Data.GetOrdersAsync();
    }

    private void AddNewOrder()
    {
        editingOrder = new Order();
        showModal = true;
    }

    private void EditOrder(Order o)
    {
        editingOrder = new Order
        {
            Id = o.Id,
            OrderNumber = o.OrderNumber,
            CustomerName = o.CustomerName,
            CustomerEmail = o.CustomerEmail,
            Status = o.Status,
            OrderDate = o.OrderDate,
            TotalAmount = o.TotalAmount,
            DepositPaid = o.DepositPaid,
            IsFullyPaid = o.IsFullyPaid
        };
        showModal = true;
    }

    private async Task SaveOrder()
    {
        await Data.SaveOrderAsync(editingOrder);
        orders = await Data.GetOrdersAsync();
        showModal = false;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "in production" => "status-in-production",
        "ready for pickup" => "status-ready",
        "deposit paid" => "status-paid",
        _ => ""
    };
}
