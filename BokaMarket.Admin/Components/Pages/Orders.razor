@page "/orders"
@inject IDataService Data

<div class="page-header">
    <h1>Orders Management</h1>
    <p style="color: var(--text-muted);">Track and curate pending artisanal commissions.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">AWAITING DEPOSIT</div>
        <div class="stat-value">12</div>
        <div style="font-size: 0.75rem; color: var(--accent-green); margin-top: 8px;">↑ +2 from yesterday</div>
    </div>
    <div class="stat-card">
        <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">IN PRODUCTION</div>
        <div class="stat-value">08</div>
        <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 8px;">4 orders due this week</div>
    </div>
    <div class="stat-card">
        <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px;">READY FOR PICKUP</div>
        <div class="stat-value">05</div>
        <div style="font-size: 0.75rem; color: #E74C3C; margin-top: 8px;">Action required</div>
    </div>
    <div class="stat-card featured">
        <div style="font-size: 0.8rem; opacity: 0.8; margin-bottom: 8px;">TOTAL MONTHLY REVENUE</div>
        <div class="stat-value">R4,820</div>
        <div style="font-size: 0.75rem; opacity: 0.8; margin-top: 8px;">Crafted with intentionality</div>
    </div>
</div>

<div class="table-container">
    <div class="table-header" style="display: flex; flex-direction: column; gap: 1rem; align-items: stretch;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h2 style="font-size: 1.25rem; font-weight: 600;">Active Orders</h2>
            <div>
                <button class="btn-primary" style="font-size: 0.85rem;" @onclick="AddNewOrder">+ ADD NEW ORDER</button>
                <button class="btn-secondary" style="font-size: 0.85rem; padding: 0.6rem 1.2rem; border-radius: 10px; font-weight: 600;">DOWNLOAD CSV</button>
            </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 200px; gap: 1rem;">
            <div class="search-box" style="position: relative;">
                <i class="bi bi-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search by Order #, Customer, or Email..." 
                       style="width: 100%; padding: 10px 10px 10px 40px; border-radius: 10px; border: 1px solid #ddd; font-family: inherit;" />
            </div>
            <select @bind="statusFilter" class="form-control" style="padding: 10px; border-radius: 10px;">
                <option value="">All Statuses</option>
                <option value="Awaiting Payment">Awaiting Payment</option>
                <option value="Deposit Paid">Deposit Paid</option>
                <option value="In Production">In Production</option>
                <option value="Shipped">Shipped</option>
                <option value="Ready for Pickup">Ready for Pickup</option>
            </select>
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Items Summary</th>
                <th>Status</th>
                <th>Payment</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in FilteredOrders)
            {
                <tr>
                    <td style="color: var(--primary); font-weight: 700;">@order.OrderNumber</td>
                    <td>
                        <div style="font-weight: 600;">@order.CustomerName</div>
                        <div style="font-size: 0.8rem; color: var(--text-muted);">@order.CustomerEmail</div>
                    </td>
                    <td style="font-size: 0.85rem; color: var(--text-muted);">
                        @if (order.Items != null && order.Items.Any())
                        {
                            <div>@string.Join(", ", order.Items.Select(i => $"{i.Quantity}x {i.ProductName}"))</div>
                        }
                        else
                        {
                            <div>General Order</div>
                        }
                    </td>
                    <td>
                        <span class="status-badge @GetStatusClass(order.Status)">@order.Status.ToUpper()</span>
                        @if (!string.IsNullOrEmpty(order.TrackingNumber))
                        {
                             <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 4px;">🚚 @order.TrackingNumber</div>
                        }
                    </td>
                    <td>
                        <div style="font-weight: 600;">@(order.IsFullyPaid ? "Fully Paid" : "Deposit Paid")</div>
                        <div style="font-size: 0.8rem; color: var(--text-muted);">(R@order.TotalAmount.ToString("N0"))</div>
                    </td>
                    <td>
                        <div style="display: flex; gap: 12px;">
                            <i class="bi bi-pencil" style="cursor: pointer; color: var(--text-muted);" @onclick="() => EditOrder(order)"></i>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingOrder.Id == 0 ? "Add New Order" : "Edit Order")</h3>
                <i class="bi bi-x-lg" style="cursor:pointer;" @onclick="CloseModal"></i>
            </div>
            
            <EditForm Model="editingOrder" OnValidSubmit="SaveOrder">
                <DataAnnotationsValidator />
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label>Customer Name</label>
                        <InputText @bind-Value="editingOrder.CustomerName" class="form-control" />
                    </div>
                    
                    <div class="form-group">
                        <label>Customer Email</label>
                        <InputText @bind-Value="editingOrder.CustomerEmail" class="form-control" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Shipping Address</label>
                    <InputTextArea @bind-Value="editingOrder.ShippingAddress" class="form-control" rows="2" />
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label>Status</label>
                        <InputSelect @bind-Value="editingOrder.Status" class="form-control">
                            <option value="Awaiting Payment">Awaiting Payment</option>
                            <option value="Deposit Paid">Deposit Paid</option>
                            <option value="In Production">In Production</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Ready for Pickup">Ready for Pickup</option>
                        </InputSelect>
                    </div>
                    
                    <div class="form-group">
                        <label>Courier Service / Method</label>
                        <InputText @bind-Value="editingOrder.CourierName" class="form-control" placeholder="e.g. Aramex, PEP Paxi" />
                    </div>
                </div>

                @if (editingOrder.Status == "Shipped")
                {
                    <div class="form-group">
                        <label style="color: var(--primary); font-weight: 800;">Tracking Number</label>
                        <InputText @bind-Value="editingOrder.TrackingNumber" class="form-control" placeholder="CN-XXXX-XXXXX" />
                    </div>
                }
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label>Total Amount (R)</label>
                        <InputNumber @bind-Value="editingOrder.TotalAmount" class="form-control" />
                    </div>
                    
                    <div class="form-group">
                        <label>Deposit Paid (R)</label>
                        <InputNumber @bind-Value="editingOrder.DepositPaid" class="form-control" />
                    </div>
                </div>
                
                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                        <InputCheckbox @bind-Value="editingOrder.IsFullyPaid" style="width: 18px; height: 18px;" /> Fully Paid
                    </label>
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn-primary">Update Order Information</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Order> allOrders = new();
    private string searchTerm = "";
    private string statusFilter = "";
    private bool showModal = false;
    private Order editingOrder = new();

    private List<Order> FilteredOrders => allOrders
        .Where(o => (string.IsNullOrEmpty(searchTerm) || 
                   o.OrderNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                   o.CustomerName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                   o.CustomerEmail.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
                  (string.IsNullOrEmpty(statusFilter) || o.Status == statusFilter))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        allOrders = await Data.GetOrdersAsync();
    }

    private void AddNewOrder()
    {
        editingOrder = new Order();
        showModal = true;
    }

    private void EditOrder(Order o)
    {
        editingOrder = new Order
        {
            Id = o.Id,
            OrderNumber = o.OrderNumber,
            CustomerName = o.CustomerName,
            CustomerEmail = o.CustomerEmail,
            ShippingAddress = o.ShippingAddress,
            Phone = o.Phone,
            Status = o.Status,
            OrderDate = o.OrderDate,
            TotalAmount = o.TotalAmount,
            DepositPaid = o.DepositPaid,
            IsFullyPaid = o.IsFullyPaid,
            TrackingNumber = o.TrackingNumber,
            CourierName = o.CourierName,
            Items = o.Items ?? new()
        };
        showModal = true;
    }

    private async Task SaveOrder()
    {
        if (editingOrder.Id == 0)
        {
            await Data.SaveOrderAsync(editingOrder);
        }
        else
        {
            await Data.UpdateOrderAsync(editingOrder);
        }
        
        allOrders = await Data.GetOrdersAsync();
        showModal = false;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private string GetStatusClass(string status) => status?.ToLower() switch
    {
        "in production" => "status-in-production",
        "ready for pickup" => "status-ready",
        "deposit paid" => "status-paid",
        "shipped" => "status-shipped",
        "awaiting payment" => "status-pending",
        _ => ""
    };
}

<style>
    .status-shipped {
        background-color: #E8F4FD;
        color: #2980B9;
    }
    .status-paid {
        background-color: #E8F8F5;
        color: #27AE60;
    }
    .status-in-production {
        background-color: #FEF9E7;
        color: #F1C40F;
    }
    .status-ready {
        background-color: #F4ECF7;
        color: #8E44AD;
    }
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }
    .modal-content {
        background: white;
        padding: 2rem;
        border-radius: 20px;
        width: 100%;
        max-width: 500px;
        max-height: 90vh;
        overflow-y: auto;
    }
</style>
