@page "/inventory"
@inject IDataService Data

<div class="page-header">
    <h1>Inventory Management</h1>
    <p style="color: var(--text-muted);">Manage your artisanal goods and digital patterns.</p>
</div>

<div class="table-container">
    <div class="table-header">
        <h2 style="font-size: 1.25rem; font-weight: 600;">Product Catalog</h2>
        <button class="btn-primary" style="font-size: 0.85rem;" @onclick="AddNewItem">+ ADD NEW ITEM</button>
    </div>
    <table>
        <thead>
            <tr>
                <th>Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td><img src="https://localhost:7123/@product.ImageUrl" style="width: 48px; height: 48px; border-radius: 8px; object-fit: cover;" onerror="this.src='https://placehold.co/48x48/F7E8FA/7E3091?text=Img';" /></td>
                    <td>
                        <div style="font-weight: 600;">@product.Name</div>
                        <div style="font-size: 0.8rem; color: var(--text-muted);">@product.Description</div>
                    </td>
                    <td style="color: var(--text-muted);">@product.Category</td>
                    <td style="font-weight: 600;">R@product.Price.ToString("N0")</td>
                    <td>
                        @if (product.InventoryCount < 10)
                        {
                            <span style="color: #E67E22; font-weight: 600;">@product.InventoryCount <small>(LOW)</small></span>
                        }
                        else
                        {
                            <span>@product.InventoryCount</span>
                        }
                    </td>
                    <td>
                        <div style="display: flex; gap: 12px;">
                            <i class="bi bi-pencil" style="cursor: pointer; color: var(--text-muted);" @onclick="() => EditItem(product)"></i>
                            <i class="bi bi-trash" style="cursor: pointer; color: #E74C3C;" @onclick="() => Delete(product.Id)"></i>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(editingProduct.Id == 0 ? "Add New Item" : "Edit Item")</h3>
                <i class="bi bi-x-lg" style="cursor:pointer;" @onclick="CloseModal"></i>
            </div>
            
            <EditForm Model="editingProduct" OnValidSubmit="SaveProduct">
                <DataAnnotationsValidator />
                
                <div class="form-group">
                    <label>Name</label>
                    <InputText @bind-Value="editingProduct.Name" class="form-control" />
                </div>
                
                <div class="form-group">
                    <label>Category</label>
                    <InputText @bind-Value="editingProduct.Category" class="form-control" />
                </div>
                
                <div class="form-group">
                    <label>Price</label>
                    <InputNumber @bind-Value="editingProduct.Price" class="form-control" />
                </div>
                
                <div class="form-group">
                    <label>Stock</label>
                    <InputNumber @bind-Value="editingProduct.InventoryCount" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Product Image</label>
                    <div style="display: flex; align-items: center; gap: 1rem; margin-top: 5px;">
                        <img src="https://localhost:7123/@editingProduct.ImageUrl" style="width: 60px; height: 60px; border-radius: 8px; object-fit: cover; border: 1px solid #eee;" onerror="this.src='https://placehold.co/60px';" />
                        <InputFile OnChange="HandleFileSelected" class="form-control" />
                    </div>
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn-primary">Save Item</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Product> products = new();
    private bool showModal = false;
    private Product editingProduct = new();
    private IBrowserFile? selectedFile;

    protected override async Task OnInitializedAsync()
    {
        products = await Data.GetProductsAsync();
    }

    private void AddNewItem()
    {
        editingProduct = new Product();
        selectedFile = null;
        showModal = true;
    }

    private void EditItem(Product p)
    {
        editingProduct = new Product
        {
            Id = p.Id,
            Name = p.Name,
            Category = p.Category,
            Price = p.Price,
            InventoryCount = p.InventoryCount,
            Description = p.Description,
            ImageUrl = p.ImageUrl
        };
        selectedFile = null;
        showModal = true;
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task SaveProduct()
    {
        if (selectedFile != null)
        {
            using var stream = selectedFile.OpenReadStream();
            var url = await Data.UploadImageAsync(stream, selectedFile.Name);
            if (url != null) editingProduct.ImageUrl = url;
        }

        await Data.SaveProductAsync(editingProduct);
        products = await Data.GetProductsAsync();
        showModal = false;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task Delete(int id)
    {
        await Data.DeleteProductAsync(id);
        products = await Data.GetProductsAsync();
    }
}
