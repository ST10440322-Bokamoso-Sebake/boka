{
  "version": 2,
  "outputDirectory": "customer/BokaMarket.Customer/bin/Release/net10.0/publish/wwwroot",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/_framework/(.*)",
      "dest": "/_framework/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
